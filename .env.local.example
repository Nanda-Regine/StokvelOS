# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://stokvelos.co.za

# ── Claude AI (Anthropic) ──────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── PayFast (South African payments) ─────────────────────────
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase

# ── 360dialog (WhatsApp Business API) ────────────────────────
# Get from: https://hub.360dialog.com
DIALOG360_API_KEY=your-360dialog-api-key
DIALOG360_NAMESPACE=your-waba-namespace
DIALOG360_WEBHOOK_SECRET=your-webhook-verify-token

# ── Notion Integration ────────────────────────────────────────
# Get from: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...
# The root page ID where stokvel workspaces will be created
# (the integration must be shared with this page)
NOTION_ROOT_PAGE_ID=your-root-page-id

# ── Vercel Cron Security ──────────────────────────────────────
# Random secret to protect cron endpoints
CRON_SECRET=your-random-cron-secret
